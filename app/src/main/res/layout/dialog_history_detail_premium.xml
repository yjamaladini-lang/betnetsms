<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/detailDialogRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_premium_dialog"
    android:layoutDirection="rtl"
    android:textDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layoutDirection="ltr">

        <ImageButton
            android:id="@+id/detailCloseTop"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:padding="10dp"
            android:src="@drawable/ic_close_premium"
            android:background="@drawable/bg_premium_action"
            android:contentDescription="بستن"
            android:visibility="invisible"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="جزئیات پیام و ارسال"
            android:textColor="@color/premium_text"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"/>

        <Space
            android:layout_width="42dp"
            android:layout_height="42dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/bg_premium_inner_card"
                android:elevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layoutDirection="ltr">

                    <TextView
                        android:id="@+id/detailSenderValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/premium_text"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:textDirection="ltr"
                        android:gravity="start"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="فرستنده:"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        android:layout_marginEnd="9dp"/>

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_green">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_user_premium"/>
                    </FrameLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/premium_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layoutDirection="ltr">

                    <TextView
                        android:id="@+id/detailAppValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/premium_text"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:textDirection="ltr"
                        android:gravity="start"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="برنامه:"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        android:layout_marginEnd="9dp"/>

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_green">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_message_premium"/>
                    </FrameLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/premium_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layoutDirection="ltr">

                    <TextView
                        android:id="@+id/detailTimeValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/premium_text"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:textDirection="ltr"
                        android:gravity="start"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="زمان شناسایی:"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        android:layout_marginEnd="9dp"/>

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_green">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_clock_premium"/>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layoutDirection="ltr">
                <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="متن پیام:"
                    android:textColor="@color/premium_text"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>
                <View
                    android:layout_width="4dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_section_accent"/>
            </LinearLayout>

            <TextView
                android:id="@+id/detailMessageValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="17dp"
                android:textColor="@color/premium_text"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:gravity="end"
                android:textDirection="rtl"
                android:background="@drawable/bg_premium_inner_card"
                android:elevation="1dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layoutDirection="ltr">
                <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تاریخچه تلاش‌ها:"
                    android:textColor="@color/premium_text"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>
                <View
                    android:layout_width="4dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_section_accent"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/detailAttemptsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"/>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:layoutDirection="ltr">

        <Button
            android:id="@+id/detailResendButton"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_weight="1"
            android:text="ارسال مجدد"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:drawableStart="@drawable/ic_send_premium"
            android:drawablePadding="8dp"
            android:background="@drawable/bg_premium_primary"/>

        <Button
            android:id="@+id/detailCloseButton"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="بستن"
            android:textColor="@color/premium_text"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:drawableStart="@drawable/ic_close_premium"
            android:drawablePadding="8dp"
            android:background="@drawable/bg_premium_secondary"/>
    </LinearLayout>
</LinearLayout>
