<?xml version='1.0' encoding='utf-8'?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@drawable/bg_ui_screen" android:layoutDirection="rtl" android:textDirection="rtl">

    <LinearLayout android:layout_width="match_parent" android:layout_height="@dimen/header_height" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:background="@color/ui_surface" android:elevation="1dp" android:layoutDirection="ltr">

        <ImageButton android:id="@+id/buttonHome" android:layout_width="38dp" android:layout_height="38dp" android:src="@drawable/ic_launcher_foreground" android:padding="7dp" android:scaleType="centerInside" android:background="@android:color/transparent" android:contentDescription="خانه" />

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Betnet SMS Sender" android:textColor="@color/ui_text" android:textSize="15sp" android:fontFamily="sans-serif-medium" android:gravity="start" android:maxLines="1" android:ellipsize="end" />

        <TextView android:layout_width="wrap_content" android:layout_height="26dp" android:minWidth="54dp" android:gravity="center" android:paddingStart="8dp" android:paddingEnd="8dp" android:text="v1.7.2" android:textColor="@color/ui_muted" android:textSize="9.5sp" android:background="@drawable/bg_ui_chip" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:fillViewport="true" android:clipToPadding="false">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="@dimen/screen_padding" android:paddingBottom="22dp">

            <LinearLayout android:id="@+id/sectionDashboard" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                <LinearLayout android:id="@+id/dashboardLatestCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="128dp" android:orientation="vertical" android:padding="@dimen/card_padding" android:background="@drawable/bg_ui_card" android:elevation="1dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="آخرین پیام" android:textColor="@color/ui_muted" android:textSize="10.5sp" android:gravity="end" android:textDirection="rtl" />

                            <TextView android:id="@+id/dashboardLatestSender" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="—" android:textColor="@color/ui_text" android:textSize="19sp" android:fontFamily="sans-serif-medium" android:maxLines="1" android:ellipsize="end" android:gravity="end" android:textDirection="rtl" />
                        </LinearLayout>

                        <TextView android:id="@+id/dashboardLatestResult" android:layout_width="wrap_content" android:layout_height="32dp" android:gravity="end" android:paddingStart="11dp" android:paddingEnd="11dp" android:text="آماده" android:textColor="@color/ui_green" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:background="@drawable/bg_ui_success" android:textDirection="rtl" />
                    </LinearLayout>

                    <TextView android:id="@+id/dashboardLatestMessage" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="هنوز پیامی دریافت نشده است." android:textColor="#334155" android:textSize="11.5sp" android:lineSpacingExtra="2dp" android:maxLines="3" android:ellipsize="end" android:gravity="end" android:textDirection="rtl" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:layout_marginTop="@dimen/section_gap" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:background="@drawable/bg_ui_card">

                    <Switch android:id="@+id/switchEnabled" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ارسال خودکار" android:textColor="@color/ui_text" android:textSize="13.5sp" android:fontFamily="sans-serif-medium" android:gravity="end" android:textDirection="rtl" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="ارسال خودکار پیام‌های دریافتی" android:textColor="@color/ui_muted" android:textSize="9.5sp" android:maxLines="1" android:ellipsize="end" android:gravity="end" android:textDirection="rtl" />
                    </LinearLayout>

                    <TextView android:id="@+id/dashboardStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="فعال" android:textColor="@color/ui_green" android:textSize="10.5sp" android:fontFamily="sans-serif-medium" android:textDirection="rtl" android:gravity="end" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/section_gap" android:orientation="vertical" android:background="@drawable/bg_ui_card">

                    <LinearLayout android:id="@+id/cardWebhook" android:layout_width="match_parent" android:layout_height="@dimen/menu_row_height" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:clickable="true" android:focusable="true">
                        <TextView android:layout_width="42dp" android:layout_height="42dp" android:gravity="center" android:text="◎" android:textSize="24sp" android:textColor="@color/ui_text" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="9dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="وب‌هوک‌ها" android:textColor="@color/ui_text" android:textSize="13.5sp" android:fontFamily="sans-serif-medium" android:gravity="end" android:textDirection="rtl" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="مدیریت آدرس و تست وب‌هوک" android:textColor="@color/ui_muted" android:textSize="9.5sp" android:maxLines="1" android:ellipsize="end" android:gravity="end" android:textDirection="rtl" />
                        </LinearLayout>
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content" android:gravity="center" android:text="‹" android:textColor="@color/ui_muted" android:textSize="22sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="14dp" android:layout_marginEnd="14dp" android:background="@color/ui_border" />

                    <LinearLayout android:id="@+id/cardHistory" android:layout_width="match_parent" android:layout_height="@dimen/menu_row_height" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:clickable="true" android:focusable="true">
                        <TextView android:layout_width="42dp" android:layout_height="42dp" android:gravity="center" android:text="◷" android:textSize="24sp" android:textColor="@color/ui_text" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="9dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="تاریخچه پیام‌ها" android:textColor="@color/ui_text" android:textSize="13.5sp" android:fontFamily="sans-serif-medium" android:gravity="end" android:textDirection="rtl" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="مشاهده و پیگیری ارسال‌ها" android:textColor="@color/ui_muted" android:textSize="9.5sp" android:maxLines="1" android:ellipsize="end" android:gravity="end" android:textDirection="rtl" />
                        </LinearLayout>
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content" android:gravity="center" android:text="‹" android:textColor="@color/ui_muted" android:textSize="22sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="14dp" android:layout_marginEnd="14dp" android:background="@color/ui_border" />

                    <LinearLayout android:id="@+id/cardManual" android:layout_width="match_parent" android:layout_height="@dimen/menu_row_height" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:clickable="true" android:focusable="true">
                        <TextView android:layout_width="42dp" android:layout_height="42dp" android:gravity="center" android:text="➤" android:textSize="23sp" android:textColor="@color/ui_text" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="9dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ارسال دستی" android:textColor="@color/ui_text" android:textSize="13.5sp" android:fontFamily="sans-serif-medium" android:gravity="end" android:textDirection="rtl" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="ارسال مستقیم متن به وب‌هوک" android:textColor="@color/ui_muted" android:textSize="9.5sp" android:maxLines="1" android:ellipsize="end" android:gravity="end" android:textDirection="rtl" />
                        </LinearLayout>
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content" android:gravity="center" android:text="‹" android:textColor="@color/ui_muted" android:textSize="22sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="14dp" android:layout_marginEnd="14dp" android:background="@color/ui_border" />

                    <LinearLayout android:id="@+id/cardSettings" android:layout_width="match_parent" android:layout_height="@dimen/menu_row_height" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp" android:clickable="true" android:focusable="true">
                        <TextView android:layout_width="42dp" android:layout_height="42dp" android:gravity="center" android:text="⚙" android:textSize="23sp" android:textColor="@color/ui_text" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="9dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="تنظیمات پیشرفته" android:textColor="@color/ui_text" android:textSize="13.5sp" android:fontFamily="sans-serif-medium" android:gravity="end" android:textDirection="rtl" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="برنامه‌ها، فیلترها و تلاش‌ها" android:textColor="@color/ui_muted" android:textSize="9.5sp" android:maxLines="1" android:ellipsize="end" android:gravity="end" android:textDirection="rtl" />
                        </LinearLayout>
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content" android:gravity="center" android:text="‹" android:textColor="@color/ui_muted" android:textSize="22sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView android:id="@+id/textStatus" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="12dp" android:gravity="end" android:text="برنامه آماده دریافت پیام است" android:textColor="#FFFFFF" android:textSize="10.5sp" android:fontFamily="sans-serif-medium" android:background="@drawable/bg_ui_dark" android:textDirection="rtl" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionWebhook" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="وب‌هوک‌ها" android:textColor="@color/ui_text" android:textSize="22sp" android:fontFamily="sans-serif-medium" android:gravity="end" android:textDirection="rtl" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" android:padding="14dp" android:background="@drawable/bg_ui_card">
                    <EditText android:id="@+id/inputWebhook" android:layout_width="match_parent" android:layout_height="52dp" android:hint="https://domain.com/webhook.php" android:inputType="textUri" android:gravity="start|center_vertical" android:padding="13dp" android:textSize="11sp" android:background="@drawable/bg_input" />
                    <Button android:id="@+id/buttonTest" android:layout_width="match_parent" android:layout_height="@dimen/button_height" android:layout_marginTop="9dp" android:text="تست وب‌هوک" android:textSize="11sp" android:textColor="@color/ui_text" android:background="@drawable/bg_ui_button" android:textDirection="rtl" />
                    <Button android:id="@+id/buttonSaveWebhook" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="9dp" android:text="ذخیره وب‌هوک" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/bg_ui_primary" android:textDirection="rtl" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionSettings" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="تنظیمات پیشرفته" android:textColor="@color/ui_text" android:textSize="22sp" android:fontFamily="sans-serif-medium" android:gravity="end" android:textDirection="rtl" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" android:padding="14dp" android:background="@drawable/bg_ui_card">
                    <Button android:id="@+id/buttonPermission" android:layout_width="match_parent" android:layout_height="48dp" android:text="دسترسی اعلان‌ها" android:textSize="11sp" android:textColor="@color/ui_text" android:background="@drawable/bg_ui_button" android:textDirection="rtl" />
                    <Button android:id="@+id/buttonStartup" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="7dp" android:text="اجرای خودکار و باتری" android:textSize="11sp" android:textColor="@color/ui_text" android:background="@drawable/bg_ui_button" android:textDirection="rtl" />
                    <Button android:id="@+id/buttonApps" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="7dp" android:text="انتخاب برنامه ارتباطی" android:textSize="11sp" android:textColor="@color/ui_text" android:background="@drawable/bg_ui_button" android:textDirection="rtl" />
                    <TextView android:id="@+id/textSelectedApps" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:textColor="@color/ui_muted" android:textSize="10sp" android:gravity="end|center_vertical" android:textDirection="rtl" />
                    <TextView android:id="@+id/dashboardAppsText" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />
                    <EditText android:id="@+id/inputSenderFilter" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="12dp" android:hint="فیلتر فرستنده" android:textSize="11sp" android:padding="12dp" android:background="@drawable/bg_input" android:gravity="end|center_vertical" android:textDirection="rtl" />
                    <EditText android:id="@+id/inputTextFilter" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="7dp" android:hint="کلمات کلیدی" android:textSize="11sp" android:padding="12dp" android:background="@drawable/bg_input" android:gravity="end|center_vertical" android:textDirection="rtl" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:orientation="horizontal">
                        <EditText android:id="@+id/inputRetryCount" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:hint="تعداد تلاش" android:textSize="10.5sp" android:inputType="number" android:padding="12dp" android:background="@drawable/bg_input" />
                        <EditText android:id="@+id/inputRetrySeconds" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_marginStart="7dp" android:hint="فاصله ثانیه" android:textSize="10.5sp" android:inputType="number" android:padding="12dp" android:background="@drawable/bg_input" />
                    </LinearLayout>
                    <Button android:id="@+id/buttonSave" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:text="ذخیره تنظیمات" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/bg_ui_dark" android:textDirection="rtl" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionHistory" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageButton android:id="@+id/buttonHistoryBack" android:layout_width="42dp" android:layout_height="42dp" android:src="@drawable/ic_back_premium" android:padding="10dp" android:background="@drawable/bg_ui_button" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="تاریخچه پیام‌ها" android:textColor="@color/ui_text" android:textSize="21sp" android:fontFamily="sans-serif-medium" android:gravity="end" android:maxLines="1" android:ellipsize="end" android:textDirection="rtl" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:layout_marginTop="10dp" android:orientation="horizontal">
                    <Button android:id="@+id/buttonRefresh" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:text="تازه‌سازی" android:textSize="10.5sp" android:textColor="@color/ui_text" android:background="@drawable/bg_ui_button" android:textDirection="rtl" />
                    <Button android:id="@+id/buttonSelectHistory" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_marginStart="7dp" android:text="انتخاب پیام‌ها" android:textSize="10.5sp" android:textColor="@color/ui_text" android:background="@drawable/bg_ui_button" android:textDirection="rtl" />
                </LinearLayout>
                <Button android:id="@+id/buttonDeleteSelected" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="7dp" android:text="حذف انتخابی" android:textSize="10.5sp" android:textColor="#B91C1C" android:background="@drawable/bg_ui_button" android:visibility="gone" android:textDirection="rtl" />
                <LinearLayout android:id="@+id/historyContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionManual" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ارسال دستی" android:textColor="@color/ui_text" android:textSize="22sp" android:fontFamily="sans-serif-medium" android:gravity="end" android:textDirection="rtl" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" android:padding="14dp" android:background="@drawable/bg_ui_card">
                    <EditText android:id="@+id/inputManualSender" android:layout_width="match_parent" android:layout_height="48dp" android:hint="فرستنده یا عنوان" android:textSize="11sp" android:padding="12dp" android:background="@drawable/bg_input" android:gravity="end|center_vertical" android:textDirection="rtl" />
                    <EditText android:id="@+id/inputManualMessage" android:layout_width="match_parent" android:layout_height="130dp" android:layout_marginTop="7dp" android:gravity="top|end" android:hint="متن پیام" android:textSize="11sp" android:padding="12dp" android:background="@drawable/bg_input" android:textDirection="rtl" />
                    <Button android:id="@+id/buttonManualSend" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:text="ارسال به وب‌هوک" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/bg_ui_primary" android:textDirection="rtl" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>