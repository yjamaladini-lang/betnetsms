<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:layoutDirection="rtl"
    android:textDirection="rtl"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:gravity="center_vertical"
        android:background="@color/card">

        <ImageView
            android:id="@+id/appLogo"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="لوگو" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">
            <TextView
                android:id="@+id/headerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Betnet SMS Sender"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="19sp"
                android:gravity="start" />
            <TextView
                android:id="@+id/headerSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="V 1.5"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:gravity="start" />
        </LinearLayout>

        <TextView
            android:id="@+id/buttonHome"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="⌂"
            android:textColor="@color/text_primary"
            android:textSize="25sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:id="@+id/sectionDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:elevation="2dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BETNET SMS SENDER"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="25sp"
                        android:gravity="center" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="ارسال امن اعلان‌های پیامکی به وب‌هوک"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:gravity="center" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ارسال خودکار" android:textSize="17sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="پس از بسته‌شدن برنامه نیز فعال می‌ماند" android:textSize="12sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                    <Switch android:id="@+id/switchEnabled" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:id="@+id/cardWebhook" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal" android:gravity="center_vertical" android:background="@drawable/bg_card" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="50dp" android:layout_height="50dp" android:gravity="center" android:text="◎" android:textSize="29sp" android:textColor="@color/text_primary" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="وب‌هوک‌ها" android:textSize="17sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="مدیریت آدرس و تست وب‌هوک" android:textSize="12sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="‹" android:textSize="28sp" android:textColor="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout android:id="@+id/cardHistory" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal" android:gravity="center_vertical" android:background="@drawable/bg_card" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="50dp" android:layout_height="50dp" android:gravity="center" android:text="↶" android:textSize="29sp" android:textColor="@color/text_primary" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="تاریخچه پیام‌ها" android:textSize="17sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="مشاهده پیام‌ها و پیگیری ارسال" android:textSize="12sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="‹" android:textSize="28sp" android:textColor="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout android:id="@+id/cardManual" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal" android:gravity="center_vertical" android:background="@drawable/bg_card" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="50dp" android:layout_height="50dp" android:gravity="center" android:text="➤" android:textSize="28sp" android:textColor="@color/text_primary" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ارسال دستی" android:textSize="17sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="ارسال مستقیم متن به وب‌هوک" android:textSize="12sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="‹" android:textSize="28sp" android:textColor="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout android:id="@+id/cardSettings" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal" android:gravity="center_vertical" android:background="@drawable/bg_card" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="50dp" android:layout_height="50dp" android:gravity="center" android:text="⚙" android:textSize="28sp" android:textColor="@color/text_primary" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="تنظیمات پیشرفته" android:textSize="17sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="برنامه پیامک، فیلترها و اجرای پس‌زمینه" android:textSize="12sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="‹" android:textSize="28sp" android:textColor="@color/text_secondary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/dashboardStatus"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:background="@drawable/bg_status"
                    android:text="●  برنامه برای اجرای عملیات مسلح است"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionWebhook" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="وب‌هوک‌ها" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="vertical" android:background="@drawable/bg_card">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="آدرس وب‌هوک" android:textStyle="bold" android:textSize="16sp" android:textColor="@color/text_primary" />
                    <EditText android:id="@+id/inputWebhook" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="https://example.com/webhook.php?token=..." android:inputType="textUri" android:textDirection="ltr" android:gravity="start" android:background="@drawable/bg_input" android:padding="13dp" />
                    <Button android:id="@+id/buttonSaveWebhook" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="14dp" android:text="ذخیره وب‌هوک" android:textColor="#FFFFFF" android:background="@drawable/bg_button_black" />
                    <Button android:id="@+id/buttonTest" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:text="تست وب‌هوک" android:textColor="@color/text_primary" android:background="@drawable/bg_button_light" />
                    <TextView android:id="@+id/textStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:textColor="@color/text_secondary" android:textSize="13sp" android:gravity="start" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionSettings" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="تنظیمات پیشرفته" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="vertical" android:background="@drawable/bg_card">
                    <Button android:id="@+id/buttonApps" android:layout_width="match_parent" android:layout_height="54dp" android:text="انتخاب برنامه‌های ارتباطی" android:textColor="@color/text_primary" android:background="@drawable/bg_button_light" />
                    <TextView android:id="@+id/textSelectedApps" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="start" />
                    <TextView android:id="@+id/dashboardAppsText" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />
                    <EditText android:id="@+id/inputSenderFilter" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:hint="فیلتر فرستنده؛ مثال: Bank, 3000" android:inputType="text" android:gravity="start" android:background="@drawable/bg_input" android:padding="13dp" />
                    <EditText android:id="@+id/inputTextFilter" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="فیلتر متن؛ مثال: واریز, انتقال" android:inputType="text" android:gravity="start" android:background="@drawable/bg_input" android:padding="13dp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:text="چند فیلتر را با ویرگول جدا کن. خالی باشد یعنی بدون محدودیت." android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="start" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
                        <EditText android:id="@+id/inputRetryCount" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="تعداد تلاش" android:inputType="number" android:background="@drawable/bg_input" android:padding="13dp" />
                        <EditText android:id="@+id/inputRetrySeconds" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:hint="فاصله ثانیه" android:inputType="number" android:background="@drawable/bg_input" android:padding="13dp" />
                    </LinearLayout>
                    <Button android:id="@+id/buttonPermission" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="14dp" android:text="دسترسی خواندن اعلان‌ها" android:textColor="@color/text_primary" android:background="@drawable/bg_button_light" />
                    <Button android:id="@+id/buttonStartup" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:text="دسترسی اجرای خودکار و باتری" android:textColor="@color/text_primary" android:background="@drawable/bg_button_light" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="برای ادامه کار پس از بسته‌شدن برنامه، محدودیت باتری را برای برنامه غیرفعال کن." android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="start" />
                    <Button android:id="@+id/buttonSave" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="16dp" android:text="ذخیره تنظیمات" android:textColor="#FFFFFF" android:background="@drawable/bg_button_black" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionHistory" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="تاریخچه پیام‌ها" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold" />
                    <Button android:id="@+id/buttonRefresh" android:layout_width="wrap_content" android:layout_height="48dp" android:text="تازه‌سازی" android:textColor="@color/text_primary" android:background="@drawable/bg_button_light" />
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="برای مشاهده جزئیات، پاسخ وب‌هوک و ارسال مجدد روی پیام بزن." android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="start" />
                <LinearLayout android:id="@+id/historyContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionManual" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ارسال دستی" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="vertical" android:background="@drawable/bg_card">
                    <EditText android:id="@+id/inputManualSender" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="فرستنده یا عنوان" android:inputType="text" android:gravity="start" android:background="@drawable/bg_input" android:padding="13dp" />
                    <EditText android:id="@+id/inputManualMessage" android:layout_width="match_parent" android:layout_height="170dp" android:layout_marginTop="12dp" android:gravity="top|start" android:hint="متنی که باید به وب‌هوک ارسال شود" android:inputType="textMultiLine" android:background="@drawable/bg_input" android:padding="13dp" />
                    <Button android:id="@+id/buttonManualSend" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="14dp" android:text="ارسال به وب‌هوک" android:textColor="#FFFFFF" android:background="@drawable/bg_button_black" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
