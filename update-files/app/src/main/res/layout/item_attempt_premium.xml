<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/attemptCardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:orientation="vertical"
    android:padding="13dp"
    android:background="@drawable/bg_premium_inner_card"
    android:elevation="1dp"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layoutDirection="ltr">

        <TextView
            android:id="@+id/attemptResult"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textSize="9.5sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_status_warning"/>

        <TextView
            android:id="@+id/attemptHttp"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginStart="7dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textSize="9.5sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_status_warning"/>

        <TextView
            android:id="@+id/attemptTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:textColor="@color/premium_muted"
            android:textSize="9.5sp"
            android:gravity="center"
            android:singleLine="true"
            android:textDirection="ltr"/>

        <TextView
            android:id="@+id/attemptNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/premium_text"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="right"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="پاسخ:"
        android:textColor="@color/premium_text"
        android:textSize="11.5sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="right"/>

    <TextView
        android:id="@+id/attemptResponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:padding="12dp"
        android:textColor="@color/premium_text"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:lineSpacingExtra="2dp"
        android:background="@drawable/bg_premium_code"
        android:textDirection="ltr"
        android:gravity="start"/>
</LinearLayout>
