                    <EditText android:id="@+id/inputManualMessage" android:layout_width="match_parent" android:layout_height="130dp" android:layout_marginTop="7dp" android:gravity="top|right" android:hint="متن پیام" android:textSize="11sp" android:padding="12dp" android:background="@drawable/bg_input" android:textDirection="rtl" android:textAlignment="gravity" />
                    <Button android:id="@+id/buttonManualSend" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:text="ارسال به وب‌هوک" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/bg_ui_primary" android:textDirection="rtl" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>