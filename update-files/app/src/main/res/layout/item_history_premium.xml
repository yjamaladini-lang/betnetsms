<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/historyCardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:orientation="vertical"
    android:padding="13dp"
    android:background="@drawable/bg_premium_card"
    android:elevation="2dp"
    android:layoutDirection="rtl"
    android:textDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layoutDirection="rtl">

        <CheckBox
            android:id="@+id/historyCheck"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:buttonTint="@color/premium_blue"
            android:visibility="gone"/>

        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="7dp"
            android:background="@drawable/bg_icon_green">

            <ImageView
                android:layout_width="21dp"
                android:layout_height="21dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_user_premium"
                android:contentDescription="فرستنده"/>
        </FrameLayout>

        <TextView
            android:id="@+id/historySender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:textColor="@color/premium_text"
            android:textSize="13.5sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="right"
            android:textAlignment="gravity"
            android:textDirection="firstStrong"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/historyTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/premium_muted"
            android:textSize="9.5sp"
            android:textDirection="ltr"
            android:gravity="left"
            android:maxLines="1"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/historyMessageSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:orientation="vertical"
        android:padding="11dp"
        android:background="@drawable/bg_history_message_warning"
        android:layoutDirection="rtl">

        <TextView
            android:id="@+id/historyMessageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/premium_text"
            android:textSize="12.5sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="right"
            android:textAlignment="gravity"
            android:textDirection="rtl"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/historyMessageBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/premium_text"
            android:textSize="11sp"
            android:lineSpacingExtra="2dp"
            android:gravity="right"
            android:textAlignment="gravity"
            android:textDirection="rtl"
            android:maxLines="3"
            android:ellipsize="end"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layoutDirection="rtl">

        <LinearLayout
            android:id="@+id/historyLinkChip"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/bg_premium_chip"
            android:layoutDirection="ltr">

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_link_premium"
                android:contentDescription="لینک"/>

            <TextView
                android:id="@+id/historyWebhook"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:textColor="@color/premium_muted"
                android:textSize="8.5sp"
                android:textDirection="ltr"
                android:gravity="left"
                android:maxLines="1"
                android:ellipsize="middle"/>
        </LinearLayout>

        <Space android:layout_width="7dp" android:layout_height="1dp"/>

        <LinearLayout
            android:id="@+id/historyStatusChip"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1.45"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/bg_status_warning">

            <ImageView
                android:id="@+id/historyStatusIcon"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:contentDescription="وضعیت"/>

            <TextView
                android:id="@+id/historyStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:textSize="8.8sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:textDirection="rtl"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
